generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(cuid())
  name      String?
  createdAt DateTime  @default(now())

  mlAccounts            MercadoLibreAccount[]
  marketplaceAccounts   MarketplaceAccount[]
  orders                Order[]
  users                 User[]
  packingLogs PackingLog[]
  deliveryPaymentConfig DeliveryPaymentConfig?
  subscription Subscription?
}
enum SubscriptionPlan {
  TRIAL
  PAID
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}
model Subscription {
  id                 String             @id @default(uuid())
  tenantId           String             @unique
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  plan               SubscriptionPlan   @default(TRIAL)
  status             SubscriptionStatus @default(ACTIVE)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}
enum Role {
  ADMIN
  SUPERVISOR
  PICKER
  DELIVERY
}

// ── Multi-marketplace enums ─────────────────────────────
enum Marketplace {
  MERCADOLIBRE
  FALABELLA
  RIPLEY
  WALMART
  HITES
}

enum OrderStatus {
  PENDING
  PICKED
  PACKED
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  CANCELLED
  RETURNED
}

model User {
  id           String   @id @default(cuid())
  email        String
  passwordHash String?
  name         String?
  role         Role     @default(PICKER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  deliveryAssignments DeliveryAssignment[]
  packingLogs PackingLog[]

  @@unique([tenantId, email])
}

model MercadoLibreAccount {
  id           String    @id @default(cuid())
  mlUserId     String
  nickname     String?
  email        String?
  accessToken  String
  refreshToken String?
  expiresIn    Int
  tokenType    String
  scope        String?
  isActive     Boolean   @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  orders   Order[]

  @@unique([tenantId, mlUserId])
}

// ── Normalized marketplace account ──────────────────────
model MarketplaceAccount {
  id           String      @id @default(uuid())
  tenantId     String
  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  marketplace  Marketplace
  nickname     String      // Display name ("Mi cuenta Falabella")

  // Credentials vary by marketplace, stored as JSON
  // ML: { accessToken, refreshToken, expiresIn, tokenType, scope, mlUserId, email }
  // Falabella: { apiKey, userId, apiUrl }
  // Ripley/Mirakl: { apiKey, shopId }
  // Walmart: { clientId, clientSecret }
  credentials  Json

  isActive     Boolean     @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  orders       Order[]     @relation("MarketplaceAccountOrders")

  @@unique([tenantId, marketplace, nickname])
  @@index([tenantId])
}

model Order {
  id            String  @id
  status        String
  totalAmount   Float
  buyerNickname String?
  packId        String?

  pickingStatus           String    @default("pending")
  shippingSubstatus       String?
  shippingStatus          String?
  shippingId              String?
  logisticType            String?
  shippingOptionName      String?
  deliveryPromise         String?
  estimatedDeliveryTime   DateTime?
  estimatedDeliveryLimit  DateTime?
  estimatedDeliveryFinal  DateTime?
  receiverCity            String?
  shippingMethodId        Int?
  shippingMethodName      String?
  shippingMethodType      String?
  shippingDeliverTo       String?
  lastUpdatedAt           DateTime?
  createdAt               DateTime  @default(now())

  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  mlAccountId String
  mlAccount   MercadoLibreAccount @relation(fields: [mlAccountId], references: [id])

  // ── Multi-marketplace fields ──
  marketplace            Marketplace
  externalOrderId        String
  marketplaceAccountId   String
  marketplaceAccount     MarketplaceAccount   @relation("MarketplaceAccountOrders", fields: [marketplaceAccountId], references: [id])
  normalizedStatus       OrderStatus
  buyerName              String?
  shippingAddress        Json?
  marketplaceCreatedAt   DateTime?

  @@unique([tenantId, marketplace, externalOrderId])
  @@index([tenantId, normalizedStatus])
  @@index([tenantId, marketplace])
  @@index([marketplaceAccountId])

  orderItems          OrderItem[]
  deliveryAssignment  DeliveryAssignment?
  packingLogs PackingLog[]
}

model PackingLog {
  id       String   @id @default(cuid())
  packedAt DateTime @default(now())
  notes    String?

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  action   String  @default("packed") 

  @@index([tenantId, packedAt])
  @@index([userId, packedAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  itemId    String
  title     String
  thumbnail String?
  quantity  Int
  variation String?
  createdAt DateTime @default(now())
}

model DeliveryAssignment {
  id         String   @id @default(cuid())
  assignedAt DateTime @default(now())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  deliveryUserId String
  deliveryUser   User   @relation(fields: [deliveryUserId], references: [id])

  paymentAmount Float
  notes         String?

  @@index([deliveryUserId, assignedAt])
}

model DeliveryPaymentConfig {
  id                String   @id @default(cuid())
  amountPerDelivery Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}