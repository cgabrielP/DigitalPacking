generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(cuid())
  name      String?
  createdAt DateTime  @default(now())

  mlAccounts            MercadoLibreAccount[]
  orders                Order[]
  users                 User[]
  deliveryPaymentConfig DeliveryPaymentConfig?
}

enum Role {
  ADMIN
  SUPERVISOR
  PICKER
  DELIVERY
}

model User {
  id           String   @id @default(cuid())
  email        String
  passwordHash String?
  name         String?
  role         Role     @default(PICKER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  deliveryAssignments DeliveryAssignment[]

  @@unique([tenantId, email])
}

model MercadoLibreAccount {
  id           String    @id @default(cuid())
  mlUserId     String
  nickname     String?
  email        String?
  accessToken  String
  refreshToken String?
  expiresIn    Int
  tokenType    String
  scope        String?
  isActive     Boolean   @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  orders   Order[]

  @@unique([tenantId, mlUserId])
}

model Order {
  id            String  @id
  status        String
  totalAmount   Float
  buyerNickname String?
  packId        String?

  pickingStatus           String    @default("pending")
  shippingSubstatus       String?
  shippingStatus          String?
  shippingId              String?
  logisticType            String?
  shippingOptionName      String?
  deliveryPromise         String?
  estimatedDeliveryTime   DateTime?
  estimatedDeliveryLimit  DateTime?
  estimatedDeliveryFinal  DateTime?
  receiverCity            String?
  shippingMethodId        Int?
  shippingMethodName      String?
  shippingMethodType      String?
  shippingDeliverTo       String?
  lastUpdatedAt           DateTime?
  createdAt               DateTime  @default(now())

  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  mlAccountId String
  mlAccount   MercadoLibreAccount @relation(fields: [mlAccountId], references: [id])

  orderItems          OrderItem[]
  deliveryAssignment  DeliveryAssignment?
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  itemId    String
  title     String
  thumbnail String?
  quantity  Int
  variation String?
  createdAt DateTime @default(now())
}

model DeliveryAssignment {
  id         String   @id @default(cuid())
  assignedAt DateTime @default(now())

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])

  deliveryUserId String
  deliveryUser   User   @relation(fields: [deliveryUserId], references: [id])

  paymentAmount Float
  notes         String?

  @@index([deliveryUserId, assignedAt])
}

model DeliveryPaymentConfig {
  id                String   @id @default(cuid())
  amountPerDelivery Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id])
}