generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(cuid())
  name      String?
  createdAt DateTime  @default(now())

  mlAccounts MercadoLibreAccount[]
  orders     Order[]
  users      User[]
}

enum Role {
  ADMIN
  SUPERVISOR
  PICKER
  DELIVERY
}

model User {
  id           String   @id @default(cuid())
  email        String
  passwordHash String?
  name         String?
  role         Role     @default(PICKER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, email])
}

model MercadoLibreAccount {
  id           String    @id @default(cuid())
  mlUserId     String
  nickname     String?
  email        String?
  accessToken  String
  refreshToken String?
  expiresIn    Int
  tokenType    String
  scope        String?
  isActive     Boolean   @default(true)
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenantId String
  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  orders   Order[]

  @@unique([tenantId, mlUserId])
}

model Order {
  id            String  @id
  status        String
  totalAmount   Float
  buyerNickname String?
  packId        String?

  pickingStatus      String    @default("pending")
  shippingSubstatus  String?
  shippingStatus     String?
  shippingId         String?
  logisticType       String?
  shippingOptionName String?
  lastUpdatedAt      DateTime?
  createdAt          DateTime  @default(now())

  tenantId    String
  tenant      Tenant              @relation(fields: [tenantId], references: [id])

  mlAccountId String
  mlAccount   MercadoLibreAccount @relation(fields: [mlAccountId], references: [id])

  orderItems OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  itemId    String
  title     String
  thumbnail String?
  quantity  Int
  variation String?
  createdAt DateTime @default(now())
}